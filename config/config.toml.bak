# 1. 确保配置目录存在
$configDir = "C:\OpenClaw\config"
if (!(Test-Path $configDir)) {
    New-Item -ItemType Directory -Path $configDir -Force
}

# 2. 定义配置文件内容（已为你剔除所有重复项和错误 Provider）
$configContent = @"
[ai]
provider = "gemini"
api_key = "AIzaSyCwjn8Tey4fxeNzmHNzKA9WF4vH6ixBIcA"
model = "gemini-1.5-flash"

[telegram]
token = "8605005604:AAEpeE6N8flruOBPRN842rO9YGMcMK48Utg"
chat_id = "8363729701"

[log]
level = "info"
"@

# 3. 将内容写入 config.toml，并强制使用 UTF8 编码以防乱码
$configPath = Join-Path $configDir "config.toml"
$configContent | Out-File -FilePath $configPath -Encoding utf8 -Force

Write-Host "------------------------------------------------" -ForegroundColor Green
Write-Host "配置文件已成功建立在: $configPath" -ForegroundColor Green
Write-Host "请记得手动修改文件中的 API_KEY、TOKEN 和 CHAT_ID！" -ForegroundColor Yellow
Write-Host "------------------------------------------------" -ForegroundColor Green